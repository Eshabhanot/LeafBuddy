<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 👋 Welcome -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome 👋"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />

        <!-- 🌡️ WEATHER CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/weather_card_bg"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="20dp">

            <TextView
                android:id="@+id/tvWeather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="37°C"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mostly Sunny ☀️"
                android:textSize="18sp"
                android:textColor="#DDDDDD"
                android:layout_marginTop="6dp" />

        </LinearLayout>

        <!-- 🌿 PLANT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Plants 🌱"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvPlantCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Plants: 0"
                android:textSize="20sp"
                android:textColor="#C5B3FF"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reminder: ..."
                android:textSize="16sp"
                android:textColor="#AAAAAA"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnAddPlant"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Add Plant 🌱"
            android:textColor="#000"
            android:background="@drawable/button_bg"
            android:layout_marginTop="30dp" />

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnViewPlants"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Explore Plants 🌍"
            android:textColor="#000"
            android:background="@drawable/button_bg"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</ScrollView>