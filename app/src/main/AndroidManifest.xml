<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="LeafBuddy 🌿"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PlantCareReminder">

        <!-- LOGIN (START SCREEN) -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- HOME -->
        <activity android:name=".HomeActivity" />

        <!-- MANAGE PLANTS (ADD + LIST) -->
        <activity android:name=".ManagePlantsActivity" />

        <!-- EXPLORE PLANTS (API) -->
        <activity android:name=".ExplorePlantsActivity" />

        <!-- PLANT DETAIL -->
        <activity android:name=".PlantDetailActivity" />

        <!-- REGISTER -->
        <activity android:name=".RegisterActivity" />

    </application>

</manifest>